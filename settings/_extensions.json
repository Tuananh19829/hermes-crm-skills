{
  "app": "crm",
  "module": "settings",
  "version": "2.1.0-ext",
  "merge_into": "_index.json",
  "skills": [
    { "name": "upload_workspace_logo", "description": "Upload logo cơ sở.", "endpoint": "POST /internal/skills/upload_workspace_logo", "input_schema": { "type": "object", "required": ["file_url"], "properties": { "file_url": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
