    { "name": "switch_workspace", "description": "Switch cơ sở.", "endpoint": "POST /internal/skills/switch_workspace", "input_schema": { "type": "object", "required": ["workspace_id"], "properties": { "workspace_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
