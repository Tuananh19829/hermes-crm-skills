{
  "app": "crm",
  "module": "documents",
  "version": "1.0.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": { "header_secret": "X-Internal-Secret", "header_user": "X-User-Id", "header_group": "X-Group-Id" },
  "skills": [
    { "name": "documents_summary", "description": "Tổng quan tài liệu theo category.", "triggers": ["tổng quan tài liệu"], "endpoint": "POST /internal/skills/documents_summary", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "list_documents", "description": "Liệt kê tài liệu theo folder/category.", "triggers": ["danh sách tài liệu"], "endpoint": "POST /internal/skills/list_documents", "input_schema": { "type": "object", "properties": { "folder_id": { "type": "string" }, "category": { "type": "string", "enum": ["staff", "customer", "contract", "policy", "other", "all"], "default": "all" }, "limit": { "type": "integer", "default": 50 } } }, "type": "action", "risk_level": "read" },
    { "name": "list_document_folders", "description": "Cấu trúc folder.", "triggers": ["folder tài liệu"], "endpoint": "POST /internal/skills/list_document_folders", "input_schema": { "type": "object", "properties": { "parent_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "get_document_url", "description": "URL preview/download.", "triggers": ["URL tài liệu"], "endpoint": "POST /internal/skills/get_document_url", "input_schema": { "type": "object", "required": ["document_id", "access_type"], "properties": { "document_id": { "type": "string" }, "access_type": { "type": "string", "enum": ["view", "download"] } } }, "type": "action", "risk_level": "read" },
    { "name": "search_documents", "description": "Search tài liệu full-text.", "triggers": ["tìm tài liệu"], "endpoint": "POST /internal/skills/search_documents", "input_schema": { "type": "object", "required": ["query"], "properties": { "query": { "type": "string" }, "category": { "type": "string" }, "folder_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_document_versions", "description": "Lịch sử versions của file.", "triggers": ["versions tài liệu"], "endpoint": "POST /internal/skills/list_document_versions", "input_schema": { "type": "object", "required": ["document_id"], "properties": { "document_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "get_document_signature_status", "description": "Trạng thái e-sign.", "triggers": ["trạng thái ký số"], "endpoint": "POST /internal/skills/get_document_signature_status", "input_schema": { "type": "object", "required": ["document_id"], "properties": { "document_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "upload_document", "description": "Upload file mới.", "triggers": ["upload tài liệu"], "endpoint": "POST /internal/skills/upload_document", "input_schema": { "type": "object", "required": ["file_url", "name"], "properties": { "file_url": { "type": "string" }, "name": { "type": "string" }, "category": { "type": "string", "enum": ["staff", "customer", "contract", "policy", "other"] }, "folder_id": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } } } }, "type": "action", "risk_level": "normal" },
    { "name": "create_document_folder", "description": "Tạo folder mới.", "triggers": ["tạo folder"], "endpoint": "POST /internal/skills/create_document_folder", "input_schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "parent_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "rename_document", "description": "Đổi tên file/folder.", "triggers": ["đổi tên tài liệu"], "endpoint": "POST /internal/skills/rename_document", "input_schema": { "type": "object", "required": ["document_id", "new_name"], "properties": { "document_id": { "type": "string" }, "new_name": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "move_document", "description": "Di chuyển file/folder.", "triggers": ["di chuyển tài liệu"], "endpoint": "POST /internal/skills/move_document", "input_schema": { "type": "object", "required": ["document_id", "new_folder_id"], "properties": { "document_id": { "type": "string" }, "new_folder_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_document", "description": "Xóa file/folder.", "triggers": ["xóa tài liệu"], "endpoint": "POST /internal/skills/delete_document", "input_schema": { "type": "object", "required": ["document_id"], "properties": { "document_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "share_document", "description": "Tạo link chia sẻ.", "triggers": ["chia sẻ tài liệu"], "endpoint": "POST /internal/skills/share_document", "input_schema": { "type": "object", "required": ["document_id", "share_type"], "properties": { "document_id": { "type": "string" }, "share_type": { "type": "string", "enum": ["public", "internal", "password_protected"] }, "expires_at": { "type": "string", "format": "date-time" }, "password": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "restore_document_version", "description": "Restore version cũ.", "triggers": ["restore version"], "endpoint": "POST /internal/skills/restore_document_version", "input_schema": { "type": "object", "required": ["document_id", "version_id"], "properties": { "document_id": { "type": "string" }, "version_id": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "set_document_permissions", "description": "Phân quyền theo role.", "triggers": ["phân quyền tài liệu"], "endpoint": "POST /internal/skills/set_document_permissions", "input_schema": { "type": "object", "required": ["document_id", "role_perms"], "properties": { "document_id": { "type": "string" }, "role_perms": { "type": "object", "description": "Map role → permissions[view/edit/delete]" } } }, "type": "action", "risk_level": "high" },
    { "name": "tag_document", "description": "Tag tài liệu.", "triggers": ["tag tài liệu"], "endpoint": "POST /internal/skills/tag_document", "input_schema": { "type": "object", "required": ["document_id", "tags"], "properties": { "document_id": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } }, "mode": { "type": "string", "enum": ["merge", "replace"], "default": "merge" } } }, "type": "action", "risk_level": "normal" },
    { "name": "request_document_signature", "description": "Yêu cầu e-sign hợp đồng.", "triggers": ["yêu cầu ký số"], "endpoint": "POST /internal/skills/request_document_signature", "input_schema": { "type": "object", "required": ["document_id", "signers"], "properties": { "document_id": { "type": "string" }, "signers": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "phone": { "type": "string" } } } }, "expires_at": { "type": "string", "format": "date-time" }, "message": { "type": "string" } } }, "type": "action", "risk_level": "high" }
  ]
}
