{
  "app": "crm",
  "module": "academy",
  "version": "1.0.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": { "header_secret": "X-Internal-Secret", "header_user": "X-User-Id", "header_group": "X-Group-Id" },
  "skills": [
    { "name": "academy_summary", "description": "Tổng quan Academy: số khóa active/paused/archived.", "triggers": ["tổng quan academy"], "endpoint": "POST /internal/skills/academy_summary", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "get_academy_course_detail", "description": "Chi tiết khóa học: modules + lessons + students enrolled.", "triggers": ["chi tiết khóa học"], "endpoint": "POST /internal/skills/get_academy_course_detail", "input_schema": { "type": "object", "required": ["course_id"], "properties": { "course_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_academy_lessons", "description": "Bài học trong khóa.", "triggers": ["danh sách bài học"], "endpoint": "POST /internal/skills/list_academy_lessons", "input_schema": { "type": "object", "required": ["course_id"], "properties": { "course_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_course_enrollments", "description": "NV đã đăng ký khóa.", "triggers": ["NV đã đăng ký"], "endpoint": "POST /internal/skills/list_course_enrollments", "input_schema": { "type": "object", "required": ["course_id"], "properties": { "course_id": { "type": "string" }, "status": { "type": "string", "enum": ["IN_PROGRESS", "COMPLETED", "DROPPED", "ALL"], "default": "ALL" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_staff_certificates", "description": "Chứng chỉ NV đã có.", "triggers": ["chứng chỉ NV"], "endpoint": "POST /internal/skills/list_staff_certificates", "input_schema": { "type": "object", "required": ["staff_id"], "properties": { "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "academy_progress_report", "description": "Báo cáo tiến độ NV.", "triggers": ["tiến độ học NV"], "endpoint": "POST /internal/skills/academy_progress_report", "input_schema": { "type": "object", "properties": { "period": { "type": "string", "enum": ["month", "quarter", "year"], "default": "month" }, "course_id": { "type": "string" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "create_academy_course", "description": "Tạo khóa học mới.", "triggers": ["tạo khóa học"], "endpoint": "POST /internal/skills/create_academy_course", "input_schema": { "type": "object", "required": ["name", "category"], "properties": { "name": { "type": "string" }, "category": { "type": "string", "enum": ["telesale", "service", "product", "soft_skill"] }, "description": { "type": "string" }, "duration_hours": { "type": "integer" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_academy_course", "description": "Sửa khóa học.", "triggers": ["sửa khóa học"], "endpoint": "POST /internal/skills/update_academy_course", "input_schema": { "type": "object", "required": ["course_id"], "properties": { "course_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_academy_course", "description": "Xóa khóa học.", "triggers": ["xóa khóa học"], "endpoint": "POST /internal/skills/delete_academy_course", "input_schema": { "type": "object", "required": ["course_id"], "properties": { "course_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "toggle_academy_course", "description": "Bật/tắt khóa học (active/paused/archived).", "triggers": ["bật tắt khóa học"], "endpoint": "POST /internal/skills/toggle_academy_course", "input_schema": { "type": "object", "required": ["course_id", "status"], "properties": { "course_id": { "type": "string" }, "status": { "type": "string", "enum": ["ACTIVE", "PAUSED", "ARCHIVED"] } } }, "type": "action", "risk_level": "normal" },
    { "name": "create_academy_lesson", "description": "Tạo bài học trong khóa.", "triggers": ["tạo bài học"], "endpoint": "POST /internal/skills/create_academy_lesson", "input_schema": { "type": "object", "required": ["course_id", "title"], "properties": { "course_id": { "type": "string" }, "title": { "type": "string" }, "content": { "type": "string" }, "video_url": { "type": "string" }, "order": { "type": "integer" }, "duration_minutes": { "type": "integer" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_academy_lesson", "description": "Sửa bài học.", "triggers": ["sửa bài học"], "endpoint": "POST /internal/skills/update_academy_lesson", "input_schema": { "type": "object", "required": ["lesson_id"], "properties": { "lesson_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_academy_lesson", "description": "Xóa bài học.", "triggers": ["xóa bài học"], "endpoint": "POST /internal/skills/delete_academy_lesson", "input_schema": { "type": "object", "required": ["lesson_id"], "properties": { "lesson_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "enroll_staff_to_course", "description": "Đăng ký NV vào khóa.", "triggers": ["đăng ký NV vào khóa"], "endpoint": "POST /internal/skills/enroll_staff_to_course", "input_schema": { "type": "object", "required": ["course_id", "staff_ids"], "properties": { "course_id": { "type": "string" }, "staff_ids": { "type": "array", "items": { "type": "string" } } } }, "type": "action", "risk_level": "normal" },
    { "name": "mark_lesson_completed", "description": "Đánh dấu bài học hoàn thành.", "triggers": ["hoàn thành bài học"], "endpoint": "POST /internal/skills/mark_lesson_completed", "input_schema": { "type": "object", "required": ["lesson_id", "staff_id"], "properties": { "lesson_id": { "type": "string" }, "staff_id": { "type": "string" }, "score": { "type": "number" } } }, "type": "action", "risk_level": "normal" },
    { "name": "issue_certificate", "description": "Cấp chứng chỉ khi NV hoàn thành khóa.", "triggers": ["cấp chứng chỉ"], "endpoint": "POST /internal/skills/issue_certificate", "input_schema": { "type": "object", "required": ["course_id", "staff_id"], "properties": { "course_id": { "type": "string" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "upload_academy_material", "description": "Upload tài liệu khóa học (PDF/video).", "triggers": ["upload tài liệu khóa học"], "endpoint": "POST /internal/skills/upload_academy_material", "input_schema": { "type": "object", "required": ["course_id", "file_url", "type"], "properties": { "course_id": { "type": "string" }, "file_url": { "type": "string" }, "type": { "type": "string", "enum": ["pdf", "video", "image", "audio", "other"] }, "title": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "manage_academy_quiz", "description": "Hybrid quản lý quiz.", "triggers": ["quiz khóa học"], "endpoint": "POST /internal/skills/manage_academy_quiz", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["create", "submit", "grade", "list"] }, "quiz_data": { "type": "object" } } }, "type": "action", "risk_level": "normal" }
  ]
}
