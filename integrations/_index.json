{
  "app": "crm",
  "module": "integrations",
  "version": "1.0.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": { "header_secret": "X-Internal-Secret", "header_user": "X-User-Id", "header_group": "X-Group-Id" },
  "description": "Module tổng hợp tích hợp ngoài: Vận chuyển, AiTrucPage, Telegram, Zalo OA mở rộng, Tích hợp tổng (App Hub).",
  "skills": [
    { "name": "list_shipping_providers", "description": "Danh sách ĐVVC khả dụng.", "triggers": ["list ĐVVC"], "endpoint": "POST /internal/skills/list_shipping_providers", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "list_connected_shipping_providers", "description": "ĐVVC đã kết nối.", "triggers": ["ĐVVC đã kết nối"], "endpoint": "POST /internal/skills/list_connected_shipping_providers", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "add_shipping_provider", "description": "Thêm kết nối ĐVVC.", "triggers": ["thêm ĐVVC"], "endpoint": "POST /internal/skills/add_shipping_provider", "input_schema": { "type": "object", "required": ["provider", "api_token"], "properties": { "provider": { "type": "string", "enum": ["GHN", "GHTK", "VTPOST", "JT", "OTHER"] }, "api_token": { "type": "string" }, "shop_id": { "type": "string" }, "active": { "type": "boolean", "default": true } } }, "type": "action", "risk_level": "high" },
    { "name": "get_pickup_address", "description": "Địa chỉ lấy hàng.", "triggers": ["địa chỉ lấy hàng"], "endpoint": "POST /internal/skills/get_pickup_address", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "update_shipping_shop_settings", "description": "Cập nhật điểm lấy hàng.", "triggers": ["cài đặt shop ĐVVC"], "endpoint": "POST /internal/skills/update_shipping_shop_settings", "input_schema": { "type": "object", "required": ["connection_id", "pickup_address"], "properties": { "connection_id": { "type": "string" }, "pickup_address": { "type": "string" }, "phone": { "type": "string" }, "contact_name": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "test_shipping_connection", "description": "Test API ĐVVC.", "triggers": ["test ĐVVC"], "endpoint": "POST /internal/skills/test_shipping_connection", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "disconnect_shipping_provider", "description": "Ngắt kết nối ĐVVC.", "triggers": ["ngắt ĐVVC"], "endpoint": "POST /internal/skills/disconnect_shipping_provider", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "calculate_shipping_fee", "description": "Tính cước phí.", "triggers": ["tính phí ship"], "endpoint": "POST /internal/skills/calculate_shipping_fee", "input_schema": { "type": "object", "required": ["connection_id", "from", "to", "weight"], "properties": { "connection_id": { "type": "string" }, "from": { "type": "object" }, "to": { "type": "object" }, "weight": { "type": "number" }, "service_type": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "create_shipping_order", "description": "Tạo đơn vận chuyển.", "triggers": ["tạo đơn ship"], "endpoint": "POST /internal/skills/create_shipping_order", "input_schema": { "type": "object", "required": ["connection_id", "order_id"], "properties": { "connection_id": { "type": "string" }, "order_id": { "type": "string" }, "package_info": { "type": "object" } } }, "type": "action", "risk_level": "high" },
    { "name": "track_shipping_order", "description": "Track tracking_code.", "triggers": ["track ship"], "endpoint": "POST /internal/skills/track_shipping_order", "input_schema": { "type": "object", "required": ["tracking_code"], "properties": { "tracking_code": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "cancel_shipping_order", "description": "Hủy đơn ship.", "triggers": ["hủy đơn ship"], "endpoint": "POST /internal/skills/cancel_shipping_order", "input_schema": { "type": "object", "required": ["tracking_code", "reason"], "properties": { "tracking_code": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "shipping_webhook", "description": "Webhook nhận status từ ĐVVC.", "triggers": ["webhook ship"], "endpoint": "POST /internal/skills/shipping_webhook", "input_schema": { "type": "object", "required": ["signature", "payload"], "properties": { "signature": { "type": "string" }, "payload": { "type": "object" } } }, "type": "action", "risk_level": "normal" },
    { "name": "shipping_report", "description": "Báo cáo vận chuyển.", "triggers": ["báo cáo ship"], "endpoint": "POST /internal/skills/shipping_report", "input_schema": { "type": "object", "properties": { "period": { "type": "string", "enum": ["today", "week", "month"] }, "provider": { "type": "string" }, "status": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_aitrucpage_connections", "description": "Page AiTrucPage đã kết nối.", "triggers": ["AiTrucPage list"], "endpoint": "POST /internal/skills/list_aitrucpage_connections", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "connect_aitrucpage", "description": "Kết nối page mới.", "triggers": ["kết nối AiTrucPage"], "endpoint": "POST /internal/skills/connect_aitrucpage", "input_schema": { "type": "object", "required": ["page_url", "api_token"], "properties": { "page_url": { "type": "string" }, "api_token": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "disconnect_aitrucpage", "description": "Ngắt page.", "triggers": ["ngắt AiTrucPage"], "endpoint": "POST /internal/skills/disconnect_aitrucpage", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "toggle_aitrucpage_auto_sync", "description": "Bật/tắt tự động sync.", "triggers": ["auto sync AiTrucPage"], "endpoint": "POST /internal/skills/toggle_aitrucpage_auto_sync", "input_schema": { "type": "object", "required": ["connection_id", "enabled"], "properties": { "connection_id": { "type": "string" }, "enabled": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_aitrucpage_sync_interval", "description": "Đổi chu kỳ sync.", "triggers": ["chu kỳ sync"], "endpoint": "POST /internal/skills/update_aitrucpage_sync_interval", "input_schema": { "type": "object", "required": ["connection_id", "interval_minutes"], "properties": { "connection_id": { "type": "string" }, "interval_minutes": { "type": "integer" } } }, "type": "action", "risk_level": "normal" },
    { "name": "sync_aitrucpage_now", "description": "Trigger sync ngay.", "triggers": ["sync ngay AiTrucPage"], "endpoint": "POST /internal/skills/sync_aitrucpage_now", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "get_aitrucpage_stats", "description": "Thống kê page.", "triggers": ["AiTrucPage stats"], "endpoint": "POST /internal/skills/get_aitrucpage_stats", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" }, "period": { "type": "string", "enum": ["today", "week", "month"] } } }, "type": "action", "risk_level": "read" },
    { "name": "list_aitrucpage_sync_history", "description": "Lịch sử sync.", "triggers": ["lịch sử sync AiTrucPage"], "endpoint": "POST /internal/skills/list_aitrucpage_sync_history", "input_schema": { "type": "object", "required": ["connection_id"], "properties": { "connection_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "submit_telegram_chat_id", "description": "Gửi chat_id để xác nhận.", "triggers": ["telegram chat_id"], "endpoint": "POST /internal/skills/submit_telegram_chat_id", "input_schema": { "type": "object", "required": ["chat_id"], "properties": { "chat_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "send_telegram_verification_code", "description": "Bot gửi code xác nhận.", "triggers": ["gửi mã telegram"], "endpoint": "POST /internal/skills/send_telegram_verification_code", "input_schema": { "type": "object", "required": ["chat_id"], "properties": { "chat_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "list_telegram_chats", "description": "Chat đã kết nối.", "triggers": ["chat telegram đã kết nối"], "endpoint": "POST /internal/skills/list_telegram_chats", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "get_telegram_chat_detail", "description": "Chi tiết chat.", "triggers": ["chi tiết chat telegram"], "endpoint": "POST /internal/skills/get_telegram_chat_detail", "input_schema": { "type": "object", "required": ["chat_id"], "properties": { "chat_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "send_test_telegram", "description": "Gửi test.", "triggers": ["test telegram"], "endpoint": "POST /internal/skills/send_test_telegram", "input_schema": { "type": "object", "required": ["chat_id", "message"], "properties": { "chat_id": { "type": "string" }, "message": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "disconnect_telegram_chat", "description": "Ngắt chat telegram.", "triggers": ["ngắt telegram"], "endpoint": "POST /internal/skills/disconnect_telegram_chat", "input_schema": { "type": "object", "required": ["chat_id"], "properties": { "chat_id": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "list_telegram_push_history", "description": "Lịch sử push telegram.", "triggers": ["lịch sử push telegram"], "endpoint": "POST /internal/skills/list_telegram_push_history", "input_schema": { "type": "object", "required": ["chat_id"], "properties": { "chat_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "create_telegram_subscription", "description": "Đăng ký event push qua telegram.", "triggers": ["đăng ký telegram"], "endpoint": "POST /internal/skills/create_telegram_subscription", "input_schema": { "type": "object", "required": ["chat_id", "event_types"], "properties": { "chat_id": { "type": "string" }, "event_types": { "type": "array", "items": { "type": "string" } }, "filter": { "type": "object" } } }, "type": "action", "risk_level": "normal" },
    { "name": "list_telegram_subscriptions", "description": "Danh sách đăng ký.", "triggers": ["danh sách đăng ký telegram"], "endpoint": "POST /internal/skills/list_telegram_subscriptions", "input_schema": { "type": "object", "properties": { "chat_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "update_telegram_subscription", "description": "Sửa đăng ký.", "triggers": ["sửa đăng ký telegram"], "endpoint": "POST /internal/skills/update_telegram_subscription", "input_schema": { "type": "object", "required": ["subscription_id"], "properties": { "subscription_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "toggle_telegram_subscription", "description": "Bật/tắt đăng ký.", "triggers": ["bật tắt telegram subscription"], "endpoint": "POST /internal/skills/toggle_telegram_subscription", "input_schema": { "type": "object", "required": ["subscription_id", "enabled"], "properties": { "subscription_id": { "type": "string" }, "enabled": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_telegram_subscription", "description": "Xóa đăng ký.", "triggers": ["xóa telegram subscription"], "endpoint": "POST /internal/skills/delete_telegram_subscription", "input_schema": { "type": "object", "required": ["subscription_id"], "properties": { "subscription_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "list_telegram_event_types", "description": "Event types push được.", "triggers": ["telegram event types"], "endpoint": "POST /internal/skills/list_telegram_event_types", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "list_app_integrations", "description": "List 4 app tích hợp tổng (AI Agent/FB/Zalo/Ads).", "triggers": ["app tích hợp"], "endpoint": "POST /internal/skills/list_app_integrations", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "list_remote_workspaces", "description": "Workspace bên app khác.", "triggers": ["remote workspace"], "endpoint": "POST /internal/skills/list_remote_workspaces", "input_schema": { "type": "object", "required": ["app"], "properties": { "app": { "type": "string", "enum": ["ai_agent", "facebook_page", "zalo", "ads"] } } }, "type": "action", "risk_level": "read" },
    { "name": "link_app_workspace", "description": "Liên kết workspace app khác.", "triggers": ["link app workspace"], "endpoint": "POST /internal/skills/link_app_workspace", "input_schema": { "type": "object", "required": ["app", "remote_workspace_id"], "properties": { "app": { "type": "string" }, "remote_workspace_id": { "type": "string" }, "is_default": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "set_default_app_workspace", "description": "Đặt mặc định.", "triggers": ["default app workspace"], "endpoint": "POST /internal/skills/set_default_app_workspace", "input_schema": { "type": "object", "required": ["app", "remote_workspace_id"], "properties": { "app": { "type": "string" }, "remote_workspace_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "unlink_app_workspace", "description": "Ngắt liên kết.", "triggers": ["unlink app"], "endpoint": "POST /internal/skills/unlink_app_workspace", "input_schema": { "type": "object", "required": ["app", "remote_workspace_id"], "properties": { "app": { "type": "string" }, "remote_workspace_id": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "verify_app_integration", "description": "Verify status app tích hợp.", "triggers": ["verify app"], "endpoint": "POST /internal/skills/verify_app_integration", "input_schema": { "type": "object", "required": ["app"], "properties": { "app": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "sync_app_data", "description": "Sync data từ app khác về CRM.", "triggers": ["sync app data"], "endpoint": "POST /internal/skills/sync_app_data", "input_schema": { "type": "object", "required": ["app", "entity_type"], "properties": { "app": { "type": "string" }, "entity_type": { "type": "string" }, "from_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "high" },
    { "name": "push_event_to_app", "description": "Push event CRM → app.", "triggers": ["push event"], "endpoint": "POST /internal/skills/push_event_to_app", "input_schema": { "type": "object", "required": ["app", "event_type", "payload"], "properties": { "app": { "type": "string" }, "event_type": { "type": "string" }, "payload": { "type": "object" } } }, "type": "action", "risk_level": "normal" },
    { "name": "list_published_events", "description": "Events đã publish.", "triggers": ["events published"], "endpoint": "POST /internal/skills/list_published_events", "input_schema": { "type": "object", "properties": { "app": { "type": "string" }, "from_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_consumed_events", "description": "Events đã consume.", "triggers": ["events consumed"], "endpoint": "POST /internal/skills/list_consumed_events", "input_schema": { "type": "object", "properties": { "app": { "type": "string" }, "from_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "read" },
    { "name": "manage_zalo_mini_app", "description": "Hybrid Zalo Mini App config.", "triggers": ["zalo mini app"], "endpoint": "POST /internal/skills/manage_zalo_mini_app", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["get", "update", "publish"] }, "app_data": { "type": "object" } } }, "type": "action", "risk_level": "high" },
    { "name": "register_zns_template", "description": "Đăng ký template ZNS với Zalo.", "triggers": ["đăng ký ZNS template"], "endpoint": "POST /internal/skills/register_zns_template", "input_schema": { "type": "object", "required": ["template_data"], "properties": { "template_data": { "type": "object" } } }, "type": "action", "risk_level": "high" }
  ]
}
