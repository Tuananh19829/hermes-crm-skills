{
  "app": "crm",
  "module": "telesale",
  "version": "1.0.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": { "header_secret": "X-Internal-Secret", "header_user": "X-User-Id", "header_group": "X-Group-Id" },
  "skills": [
    { "name": "telesale_overdue_callbacks", "description": "Đếm callback quá hạn cần xử lý.", "triggers": ["callback quá hạn"], "endpoint": "POST /internal/skills/telesale_overdue_callbacks", "input_schema": { "type": "object", "properties": { "as_of_date": { "type": "string", "format": "date-time" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "telesale_leads_breakdown", "description": "Breakdown KH tiềm năng theo trạng thái (Tổng/Lead mới/Đã tiếp cận/Quan tâm/Chưa LH/Chuyển KH).", "triggers": ["breakdown leads"], "endpoint": "POST /internal/skills/telesale_leads_breakdown", "input_schema": { "type": "object", "properties": { "period": { "type": "string", "enum": ["today", "week", "month"] }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_uncalled_leads", "description": "Lead chưa từng gọi (call_count=0).", "triggers": ["leads chưa gọi"], "endpoint": "POST /internal/skills/list_uncalled_leads", "input_schema": { "type": "object", "properties": { "assigned_to": { "type": "string" }, "limit": { "type": "integer", "default": 50 } } }, "type": "action", "risk_level": "read" },
    { "name": "list_call_history", "description": "Lịch sử cuộc gọi telesale.", "triggers": ["lịch sử cuộc gọi"], "endpoint": "POST /internal/skills/list_call_history", "input_schema": { "type": "object", "properties": { "from_date": { "type": "string", "format": "date" }, "to_date": { "type": "string", "format": "date" }, "staff_id": { "type": "string" }, "result": { "type": "string", "enum": ["ANSWERED", "NO_ANSWER", "BUSY", "CALLBACK", "WON", "NOT_INTERESTED"] }, "person_id": { "type": "string" }, "limit": { "type": "integer", "default": 50 }, "offset": { "type": "integer", "default": 0 } } }, "type": "action", "risk_level": "read" },
    { "name": "get_call_detail", "description": "Chi tiết cuộc gọi + audio nếu có.", "triggers": ["chi tiết cuộc gọi"], "endpoint": "POST /internal/skills/get_call_detail", "input_schema": { "type": "object", "required": ["call_id"], "properties": { "call_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_callbacks", "description": "Danh sách callback (chưa xong / đã xong).", "triggers": ["danh sách callback"], "endpoint": "POST /internal/skills/list_callbacks", "input_schema": { "type": "object", "properties": { "status": { "type": "string", "enum": ["pending", "done", "all"], "default": "pending" }, "staff_id": { "type": "string" }, "date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_telesale_campaigns", "description": "Danh sách chiến dịch telesale.", "triggers": ["danh sách chiến dịch telesale"], "endpoint": "POST /internal/skills/list_telesale_campaigns", "input_schema": { "type": "object", "properties": { "status": { "type": "string", "enum": ["DRAFT", "ACTIVE", "PAUSED", "ENDED", "ALL"], "default": "ALL" } } }, "type": "action", "risk_level": "read" },
    { "name": "get_telesale_campaign_detail", "description": "Chi tiết chiến dịch telesale.", "triggers": ["chi tiết chiến dịch"], "endpoint": "POST /internal/skills/get_telesale_campaign_detail", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "telesale_campaign_report", "description": "Báo cáo hiệu quả campaign telesale.", "triggers": ["báo cáo campaign telesale"], "endpoint": "POST /internal/skills/telesale_campaign_report", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" }, "period": { "type": "string", "enum": ["today", "week", "month"] } } }, "type": "action", "risk_level": "read" },
    { "name": "list_ai_call_reviews", "description": "Danh sách AI review cho cuộc gọi.", "triggers": ["AI review cuộc gọi"], "endpoint": "POST /internal/skills/list_ai_call_reviews", "input_schema": { "type": "object", "properties": { "rating": { "type": "string" }, "from_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "read" },
    { "name": "get_ai_call_review", "description": "Chi tiết AI review.", "triggers": ["chi tiết AI review"], "endpoint": "POST /internal/skills/get_ai_call_review", "input_schema": { "type": "object", "required": ["recording_id"], "properties": { "recording_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "export_leads", "description": "Export Excel leads.", "triggers": ["export leads"], "endpoint": "POST /internal/skills/export_leads", "input_schema": { "type": "object", "properties": { "filter": { "type": "object" }, "format": { "type": "string", "enum": ["xlsx", "csv"], "default": "xlsx" } } }, "type": "action", "risk_level": "read" },
    { "name": "update_lead", "description": "Sửa thông tin lead.", "triggers": ["sửa lead"], "endpoint": "POST /internal/skills/update_lead", "input_schema": { "type": "object", "required": ["lead_id"], "properties": { "lead_id": { "type": "string" }, "full_name": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" }, "note": { "type": "string" }, "interested_services": { "type": "array", "items": { "type": "string" } } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_lead", "description": "Xóa lead.", "triggers": ["xóa lead"], "endpoint": "POST /internal/skills/delete_lead", "input_schema": { "type": "object", "required": ["lead_id"], "properties": { "lead_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "assign_lead_to_staff", "description": "Gán lead cho NV.", "triggers": ["gán lead"], "endpoint": "POST /internal/skills/assign_lead_to_staff", "input_schema": { "type": "object", "required": ["lead_id", "staff_id"], "properties": { "lead_id": { "type": "string" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "convert_lead_to_customer", "description": "Chuyển lead thành KH chính thức (giữ history).", "triggers": ["chuyển lead thành KH"], "endpoint": "POST /internal/skills/convert_lead_to_customer", "input_schema": { "type": "object", "required": ["lead_id"], "properties": { "lead_id": { "type": "string" }, "tier": { "type": "string", "enum": ["NORMAL", "VIP"] } } }, "type": "action", "risk_level": "high" },
    { "name": "bulk_update_leads", "description": "Bulk action trên nhiều lead.", "triggers": ["bulk leads"], "endpoint": "POST /internal/skills/bulk_update_leads", "input_schema": { "type": "object", "required": ["lead_ids", "action"], "properties": { "lead_ids": { "type": "array", "items": { "type": "string" }, "maxItems": 200 }, "action": { "type": "string", "enum": ["assign", "set_status", "delete", "convert"] }, "staff_id": { "type": "string" }, "status": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "import_leads", "description": "Import Excel leads.", "triggers": ["import leads"], "endpoint": "POST /internal/skills/import_leads", "input_schema": { "type": "object", "required": ["file_url"], "properties": { "file_url": { "type": "string" }, "mapping": { "type": "object" }, "skip_duplicates": { "type": "boolean", "default": true } } }, "type": "action", "risk_level": "high" },
    { "name": "upload_lead_recording", "description": "Upload ghi âm cho lead.", "triggers": ["upload ghi âm lead"], "endpoint": "POST /internal/skills/upload_lead_recording", "input_schema": { "type": "object", "required": ["lead_id", "file_url"], "properties": { "lead_id": { "type": "string" }, "file_url": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "initiate_call", "description": "Khởi tạo cuộc gọi (mở dialer + log).", "triggers": ["gọi điện", "initiate call"], "endpoint": "POST /internal/skills/initiate_call", "input_schema": { "type": "object", "required": ["person_id", "staff_id"], "properties": { "person_id": { "type": "string" }, "staff_id": { "type": "string" }, "campaign_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_call_log", "description": "Sửa log cuộc gọi.", "triggers": ["sửa log gọi"], "endpoint": "POST /internal/skills/update_call_log", "input_schema": { "type": "object", "required": ["call_id"], "properties": { "call_id": { "type": "string" }, "result": { "type": "string" }, "note": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_call_log", "description": "Xóa log cuộc gọi.", "triggers": ["xóa log gọi"], "endpoint": "POST /internal/skills/delete_call_log", "input_schema": { "type": "object", "required": ["call_id"], "properties": { "call_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "initiate_callback", "description": "Mở dialer cho callback.", "triggers": ["thực hiện callback"], "endpoint": "POST /internal/skills/initiate_callback", "input_schema": { "type": "object", "required": ["callback_id"], "properties": { "callback_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "mark_callback_done", "description": "Đánh dấu callback xong.", "triggers": ["callback xong"], "endpoint": "POST /internal/skills/mark_callback_done", "input_schema": { "type": "object", "required": ["callback_id", "result"], "properties": { "callback_id": { "type": "string" }, "result": { "type": "string", "enum": ["ANSWERED", "NO_ANSWER", "WON", "LOST"] }, "note": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "reschedule_callback", "description": "Đẩy callback sang giờ mới.", "triggers": ["đẩy callback"], "endpoint": "POST /internal/skills/reschedule_callback", "input_schema": { "type": "object", "required": ["callback_id", "new_callback_at"], "properties": { "callback_id": { "type": "string" }, "new_callback_at": { "type": "string", "format": "date-time" } } }, "type": "action", "risk_level": "normal" },
    { "name": "toggle_auto_campaign", "description": "Bật/tắt chế độ auto của campaign telesale.", "triggers": ["bật auto telesale"], "endpoint": "POST /internal/skills/toggle_auto_campaign", "input_schema": { "type": "object", "required": ["campaign_id", "enabled"], "properties": { "campaign_id": { "type": "string" }, "enabled": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "create_telesale_campaign", "description": "Tạo chiến dịch telesale.", "triggers": ["tạo chiến dịch telesale"], "endpoint": "POST /internal/skills/create_telesale_campaign", "input_schema": { "type": "object", "required": ["name", "start_date"], "properties": { "name": { "type": "string" }, "target_lead_filter": { "type": "object" }, "script_id": { "type": "string" }, "assigned_staff": { "type": "array", "items": { "type": "string" } }, "start_date": { "type": "string", "format": "date" }, "end_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "high" },
    { "name": "update_telesale_campaign", "description": "Sửa chiến dịch telesale.", "triggers": ["sửa chiến dịch telesale"], "endpoint": "POST /internal/skills/update_telesale_campaign", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_telesale_campaign", "description": "Xóa chiến dịch telesale.", "triggers": ["xóa chiến dịch telesale"], "endpoint": "POST /internal/skills/delete_telesale_campaign", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "upload_call_recording", "description": "Upload ghi âm cuộc gọi.", "triggers": ["upload ghi âm gọi"], "endpoint": "POST /internal/skills/upload_call_recording", "input_schema": { "type": "object", "required": ["call_id", "file_url"], "properties": { "call_id": { "type": "string" }, "file_url": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "ai_analyze_call_recording", "description": "AI phân tích ghi âm: transcript+sentiment+suggestions.", "triggers": ["AI phân tích ghi âm"], "endpoint": "POST /internal/skills/ai_analyze_call_recording", "input_schema": { "type": "object", "required": ["recording_id"], "properties": { "recording_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "rate_call_review", "description": "Đánh giá AI review (good/bad).", "triggers": ["rate AI review"], "endpoint": "POST /internal/skills/rate_call_review", "input_schema": { "type": "object", "required": ["recording_id", "rating"], "properties": { "recording_id": { "type": "string" }, "rating": { "type": "string", "enum": ["good", "bad", "neutral"] }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "normal" }
  ]
}
