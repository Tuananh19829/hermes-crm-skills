{
  "app": "crm",
  "module": "ai_assistant",
  "version": "1.0.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": { "header_secret": "X-Internal-Secret", "header_user": "X-User-Id", "header_group": "X-Group-Id" },
  "skills": [
    { "name": "ai_assistant_status", "description": "Trạng thái online + queue + quota của AI assistant.", "triggers": ["AI status"], "endpoint": "POST /internal/skills/ai_assistant_status", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "ai_assistant_intro", "description": "Welcome message + capabilities AI hiện có.", "triggers": ["AI intro"], "endpoint": "POST /internal/skills/ai_assistant_intro", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "ai_assistant_chat_stream", "description": "SSE stream cho chat (typing real-time).", "triggers": ["AI stream"], "endpoint": "POST /internal/skills/ai_assistant_chat_stream", "input_schema": { "type": "object", "required": ["message"], "properties": { "message": { "type": "string" }, "session_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "list_ai_conversations", "description": "Lịch sử hội thoại AI của user.", "triggers": ["lịch sử AI chat"], "endpoint": "POST /internal/skills/list_ai_conversations", "input_schema": { "type": "object", "properties": { "from_date": { "type": "string", "format": "date" }, "focus": { "type": "string" }, "limit": { "type": "integer", "default": 30 } } }, "type": "action", "risk_level": "read" },
    { "name": "get_ai_conversation", "description": "Mở hội thoại cũ.", "triggers": ["mở AI chat cũ"], "endpoint": "POST /internal/skills/get_ai_conversation", "input_schema": { "type": "object", "required": ["conversation_id"], "properties": { "conversation_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_ai_prompt_suggestions", "description": "Quick prompts gợi ý theo context.", "triggers": ["AI prompt gợi ý"], "endpoint": "POST /internal/skills/list_ai_prompt_suggestions", "input_schema": { "type": "object", "properties": { "context_focus": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "get_ai_usage", "description": "Token usage tracker.", "triggers": ["AI usage"], "endpoint": "POST /internal/skills/get_ai_usage", "input_schema": { "type": "object", "properties": { "period": { "type": "string", "enum": ["today", "week", "month"], "default": "month" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "export_ai_conversation", "description": "Export hội thoại PDF/Markdown.", "triggers": ["export AI chat"], "endpoint": "POST /internal/skills/export_ai_conversation", "input_schema": { "type": "object", "required": ["conversation_id"], "properties": { "conversation_id": { "type": "string" }, "format": { "type": "string", "enum": ["pdf", "markdown", "txt"], "default": "pdf" } } }, "type": "action", "risk_level": "read" },
    { "name": "create_ai_conversation", "description": "Tạo hội thoại mới (clear context).", "triggers": ["AI chat mới"], "endpoint": "POST /internal/skills/create_ai_conversation", "input_schema": { "type": "object", "properties": { "initial_context": { "type": "object" }, "title": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_ai_conversation", "description": "Xóa hội thoại.", "triggers": ["xóa AI chat"], "endpoint": "POST /internal/skills/delete_ai_conversation", "input_schema": { "type": "object", "required": ["conversation_id"], "properties": { "conversation_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "rename_ai_conversation", "description": "Đổi tên hội thoại.", "triggers": ["đổi tên AI chat"], "endpoint": "POST /internal/skills/rename_ai_conversation", "input_schema": { "type": "object", "required": ["conversation_id", "title"], "properties": { "conversation_id": { "type": "string" }, "title": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "pin_ai_message", "description": "Ghim message quan trọng.", "triggers": ["pin AI message"], "endpoint": "POST /internal/skills/pin_ai_message", "input_schema": { "type": "object", "required": ["message_id"], "properties": { "message_id": { "type": "string" }, "pinned": { "type": "boolean", "default": true } } }, "type": "action", "risk_level": "normal" },
    { "name": "rate_ai_response", "description": "Like/Dislike feedback cho response.", "triggers": ["rate AI response"], "endpoint": "POST /internal/skills/rate_ai_response", "input_schema": { "type": "object", "required": ["message_id", "rating"], "properties": { "message_id": { "type": "string" }, "rating": { "type": "string", "enum": ["thumb_up", "thumb_down"] }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "ai_assistant_chat_with_attachment", "description": "Chat kèm file/ảnh.", "triggers": ["AI chat kèm file"], "endpoint": "POST /internal/skills/ai_assistant_chat_with_attachment", "input_schema": { "type": "object", "required": ["message", "attachments"], "properties": { "message": { "type": "string" }, "attachments": { "type": "array", "items": { "type": "object", "properties": { "url": { "type": "string" }, "type": { "type": "string" } } } } } }, "type": "action", "risk_level": "normal" },
    { "name": "ai_speech_to_text", "description": "Voice input → text.", "triggers": ["voice to text"], "endpoint": "POST /internal/skills/ai_speech_to_text", "input_schema": { "type": "object", "required": ["audio_file_url"], "properties": { "audio_file_url": { "type": "string" }, "language": { "type": "string", "default": "vi" } } }, "type": "action", "risk_level": "normal" },
    { "name": "ai_text_to_speech", "description": "Text → voice.", "triggers": ["text to voice"], "endpoint": "POST /internal/skills/ai_text_to_speech", "input_schema": { "type": "object", "required": ["text"], "properties": { "text": { "type": "string" }, "voice_id": { "type": "string", "default": "vi-female-1" } } }, "type": "action", "risk_level": "normal" },
    { "name": "manage_ai_persona", "description": "Hybrid cấu hình AI persona (giọng văn/chuyên môn).", "triggers": ["AI persona"], "endpoint": "POST /internal/skills/manage_ai_persona", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["get", "update"] }, "persona_data": { "type": "object" } } }, "type": "action", "risk_level": "normal" },
    { "name": "manage_ai_knowledge_base", "description": "Hybrid quản lý knowledge base RAG.", "triggers": ["AI knowledge base"], "endpoint": "POST /internal/skills/manage_ai_knowledge_base", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["list", "upload_doc", "delete_doc", "rebuild_index"] }, "doc_id": { "type": "string" }, "doc_data": { "type": "object" } } }, "type": "action", "risk_level": "high" },
    { "name": "ai_skill_executor", "description": "Backbone: AI nhận tool_call từ chat → execute skill khác → trả result. Dùng cho tool_use mode.", "triggers": ["AI execute tool"], "endpoint": "POST /internal/skills/ai_skill_executor", "input_schema": { "type": "object", "required": ["skill_name", "params"], "properties": { "skill_name": { "type": "string" }, "params": { "type": "object" }, "session_id": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "ai_get_capabilities", "description": "Manifest skills mà AI được phép gọi (filtered by user role).", "triggers": ["AI capabilities"], "endpoint": "POST /internal/skills/ai_get_capabilities", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" }
  ]
}
