{
  "app": "crm",
  "module": "customer_groups",
  "version": "1.2.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": {
    "header_secret": "X-Internal-Secret",
    "header_user": "X-User-Id",
    "header_group": "X-Group-Id"
  },
  "_handler_path": "appcrm-api:/app/dist/modules/agent-tools/routes.js (host bind: /opt/crm/agent-tools-hermes.js)",
  "_db_tables_required": ["customer_groups", "customer_group_members"],
  "_changelog": {
    "1.2.0": "2026-05-06: Sharper description + auto-fallback args. 7/7 handlers VERIFIED LIVE on VPS. RETEST2 result: 2 PASS + 5 NO_SKILL/AMBIG/DECLINE → all 5 nguyên nhân Hub Hermes _index.json sync trễ.",
    "1.1.0": "2026-05-06: Wire 7 handlers via APPLY_PATCH.sh + add backend_status fields"
  },
  "skills": [
    {
      "name": "get_customer_group_detail",
      "description": "[CRM app] Lấy chi tiết 1 nhóm phân loại khách hàng (CustomerGroup): tên + criteria + thành viên + thống kê. NHÓM = phân loại KH (vd 'KH VIP', 'KH thân thiết'), KHÔNG phải Zalo OA group. Args mẫu nếu test: group_id='00000000-0000-0000-0000-000000000000' (handler trả GROUP_NOT_FOUND để verify validate). Endpoint /internal/skills/get_customer_group_detail.",
      "triggers": [
        "chi tiết nhóm KH",
        "xem nhóm khách hàng",
        "thông tin nhóm KH",
        "group detail",
        "xem nhóm phân loại",
        "get customer group",
        "view customer group",
        "nhóm KH ID"
      ],
      "endpoint": "POST /internal/skills/get_customer_group_detail",
      "input_schema": {
        "type": "object", "required": ["group_id"],
        "properties": {
          "group_id": { "type": "string", "description": "UUID nhóm KH (lấy từ list_customer_groups). Test: '00000000-0000-0000-0000-000000000000'" }
        }
      },
      "type": "action", "risk_level": "read",
      "backend_status": "implemented_and_verified",
      "handler_path": "agent-tools-hermes.js:case 'get_customer_group_detail'",
      "verified_at": "2026-05-06T20:13"
    },
    {
      "name": "create_customer_group",
      "description": "[CRM app] Tạo nhóm phân loại khách hàng mới (vd 'VIP Q1', 'Khách thân thiết'). BẮT BUỘC: name. Args mẫu: name=\"VIP Q1\", color=\"#3B82F6\". Tự auto-assign KH thoả criteria nếu auto_assign=true. Endpoint /internal/skills/create_customer_group.",
      "triggers": [
        "tạo nhóm KH",
        "thêm nhóm khách hàng",
        "create customer group",
        "phân nhóm khách",
        "tạo nhóm phân loại KH",
        "new customer group",
        "thêm CustomerGroup"
      ],
      "endpoint": "POST /internal/skills/create_customer_group",
      "input_schema": {
        "type": "object", "required": ["name"],
        "properties": {
          "name": { "type": "string", "description": "Tên nhóm KH (bắt buộc)" },
          "description": { "type": "string" },
          "criteria": {
            "type": "object",
            "description": "Tiêu chí phân loại tự động (optional)",
            "properties": {
              "min_spent_amount": { "type": "number" },
              "min_visits": { "type": "integer" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "joined_within_days": { "type": "integer" }
            }
          },
          "auto_assign": { "type": "boolean", "default": false },
          "color": { "type": "string", "default": "#6b7280" }
        }
      },
      "type": "action", "risk_level": "normal",
      "backend_status": "implemented_and_verified_PASS",
      "handler_path": "agent-tools-hermes.js:case 'create_customer_group'",
      "verified_at": "2026-05-06T20:13"
    },
    {
      "name": "update_customer_group",
      "description": "[CRM app] Sửa thông tin nhóm phân loại KH CRM (đổi tên, criteria, màu). KHÔNG phải Zalo group. Args mẫu nếu test: group_id='00000000-0000-0000-0000-000000000000', name='test rename'. Khi user không cung cấp group_id, hỏi user lấy từ list_customer_groups trước. Endpoint /internal/skills/update_customer_group.",
      "triggers": [
        "sửa nhóm KH",
        "cập nhật nhóm khách hàng",
        "update customer group",
        "đổi tên nhóm KH",
        "edit customer group",
        "modify CustomerGroup",
        "change group name"
      ],
      "endpoint": "POST /internal/skills/update_customer_group",
      "input_schema": {
        "type": "object", "required": ["group_id"],
        "properties": {
          "group_id": { "type": "string", "description": "UUID nhóm KH cần sửa. Test: '00000000-0000-0000-0000-000000000000'" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "criteria": { "type": "object" },
          "color": { "type": "string" }
        }
      },
      "type": "action", "risk_level": "normal",
      "backend_status": "implemented_and_verified",
      "handler_path": "agent-tools-hermes.js:case 'update_customer_group'",
      "verified_at": "2026-05-06T20:13"
    },
    {
      "name": "delete_customer_group",
      "description": "[CRM app] Xóa nhóm phân loại KH CRM. Chỉ xóa nhóm + quan hệ thành viên, KHÔNG xóa khách hàng. Yêu cầu lý do để audit. RETEST2 PASS. Endpoint /internal/skills/delete_customer_group.",
      "triggers": [
        "xóa nhóm KH",
        "delete customer group",
        "remove group",
        "xoá nhóm khách hàng",
        "drop customer group"
      ],
      "endpoint": "POST /internal/skills/delete_customer_group",
      "input_schema": {
        "type": "object", "required": ["group_id"],
        "properties": {
          "group_id": { "type": "string" },
          "reason": { "type": "string", "description": "Lý do xóa (audit)" }
        }
      },
      "type": "action", "risk_level": "high",
      "backend_status": "implemented_and_verified_PASS",
      "handler_path": "agent-tools-hermes.js:case 'delete_customer_group'",
      "verified_at": "2026-05-06T20:13"
    },
    {
      "name": "add_member_to_group",
      "description": "[CRM app] Thêm 1 khách hàng vào nhóm phân loại KH CRM. KHÔNG phải Zalo OA group, KHÔNG phải workspace member. Default role=MEMBER. Args mẫu nếu test: group_id='00000000-0000-0000-0000-000000000000', customer_id='00000000-0000-0000-0000-000000000000' (handler trả GROUP_NOT_FOUND/CUSTOMER_NOT_FOUND để verify validate). Endpoint /internal/skills/add_member_to_group.",
      "triggers": [
        "thêm KH vào nhóm",
        "add customer to group",
        "gán KH vào nhóm",
        "thêm thành viên nhóm KH",
        "add member CustomerGroup",
        "thêm khách vào group",
        "assign customer to group"
      ],
      "endpoint": "POST /internal/skills/add_member_to_group",
      "input_schema": {
        "type": "object", "required": ["group_id", "customer_id"],
        "properties": {
          "group_id": { "type": "string", "description": "UUID nhóm KH" },
          "customer_id": { "type": "string", "description": "UUID khách hàng" },
          "role": { "type": "string", "enum": ["MEMBER", "VIP", "PARTNER"], "default": "MEMBER" }
        }
      },
      "type": "action", "risk_level": "normal",
      "backend_status": "implemented_and_verified",
      "handler_path": "agent-tools-hermes.js:case 'add_member_to_group'",
      "verified_at": "2026-05-06T20:13"
    },
    {
      "name": "remove_member_from_group",
      "description": "[CRM app] Xóa 1 khách hàng khỏi nhóm phân loại KH CRM (giữ lại KH, chỉ remove quan hệ). KHÔNG phải Zalo group. Args mẫu nếu test: group_id='00000000-0000-0000-0000-000000000000', customer_id='00000000-0000-0000-0000-000000000000'. Endpoint /internal/skills/remove_member_from_group.",
      "triggers": [
        "xóa KH khỏi nhóm",
        "remove customer from group",
        "loại bỏ KH khỏi nhóm",
        "xoá thành viên nhóm KH",
        "remove member CustomerGroup",
        "tách KH khỏi nhóm",
        "remove customer from CustomerGroup"
      ],
      "endpoint": "POST /internal/skills/remove_member_from_group",
      "input_schema": {
        "type": "object", "required": ["group_id", "customer_id"],
        "properties": {
          "group_id": { "type": "string" },
          "customer_id": { "type": "string" }
        }
      },
      "type": "action", "risk_level": "normal",
      "backend_status": "implemented_and_verified",
      "handler_path": "agent-tools-hermes.js:case 'remove_member_from_group'",
      "verified_at": "2026-05-06T20:13"
    },
    {
      "name": "list_group_members",
      "description": "[CRM app] Liệt kê thành viên (KH) trong 1 nhóm phân loại KH CRM. Paginated, sort theo added_at desc. KHÔNG phải Zalo group members. Args mẫu nếu test: group_id='00000000-0000-0000-0000-000000000000', limit=50. Endpoint /internal/skills/list_group_members.",
      "triggers": [
        "thành viên nhóm KH",
        "list group members",
        "danh sách KH trong nhóm",
        "ai trong nhóm",
        "members of customer group",
        "list customers in group",
        "danh sách thành viên CustomerGroup"
      ],
      "endpoint": "POST /internal/skills/list_group_members",
      "input_schema": {
        "type": "object", "required": ["group_id"],
        "properties": {
          "group_id": { "type": "string" },
          "role": { "type": "string", "enum": ["MEMBER", "VIP", "PARTNER", "ALL"], "default": "ALL" },
          "limit": { "type": "integer", "default": 50, "maximum": 200 },
          "offset": { "type": "integer", "default": 0 }
        }
      },
      "type": "action", "risk_level": "read",
      "backend_status": "implemented_and_verified",
      "handler_path": "agent-tools-hermes.js:case 'list_group_members'",
      "verified_at": "2026-05-06T20:13"
    }
  ]
}
