{
  "app": "crm",
  "module": "reports",
  "version": "2.1.0-ext",
  "merge_into": "_index.json",
  "skills": [
    { "name": "cashier_ranking_report", "description": "Xếp hạng thu ngân.", "endpoint": "POST /internal/skills/cashier_ranking_report", "input_schema": { "type": "object", "required": ["period"], "properties": { "period": { "type": "string" }, "top_n": { "type": "integer", "default": 10 }, "sort_by": { "type": "string", "enum": ["revenue", "invoice_count"], "default": "revenue" } } }, "type": "action", "risk_level": "read" },
    { "name": "product_service_revenue_breakdown", "description": "Doanh thu theo SP/DV.", "endpoint": "POST /internal/skills/product_service_revenue_breakdown", "input_schema": { "type": "object", "required": ["period"], "properties": { "period": { "type": "string" }, "type": { "type": "string", "enum": ["service", "product", "all"], "default": "all" }, "category_id": { "type": "string" }, "top_n": { "type": "integer", "default": 20 } } }, "type": "action", "risk_level": "read" },
    { "name": "export_branch_revenue", "description": "Export doanh thu chi nhánh.", "endpoint": "POST /internal/skills/export_branch_revenue", "input_schema": { "type": "object", "required": ["period"], "properties": { "period": { "type": "string" }, "branch_id": { "type": "string" }, "format": { "type": "string", "default": "xlsx" } } }, "type": "action", "risk_level": "read" },
    { "name": "customer_revenue_ranking", "description": "Top KH theo doanh thu.", "endpoint": "POST /internal/skills/customer_revenue_ranking", "input_schema": { "type": "object", "required": ["period"], "properties": { "period": { "type": "string" }, "top_n": { "type": "integer", "default": 20 }, "sort_by": { "type": "string", "enum": ["revenue", "frequency", "ltv"], "default": "revenue" } } }, "type": "action", "risk_level": "read" },
    { "name": "orders_revenue_by_channel", "description": "Doanh thu đơn theo channel.", "endpoint": "POST /internal/skills/orders_revenue_by_channel", "input_schema": { "type": "object", "properties": { "period": { "type": "string" }, "channel": { "type": "string" }, "sort_by": { "type": "string", "enum": ["revenue", "count"], "default": "revenue" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_advanced_reports", "description": "List báo cáo nâng cao.", "endpoint": "POST /internal/skills/list_advanced_reports", "input_schema": { "type": "object", "properties": { "category": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "create_custom_report", "description": "Tạo báo cáo tuỳ chỉnh.", "endpoint": "POST /internal/skills/create_custom_report", "input_schema": { "type": "object", "required": ["name", "data_source"], "properties": { "name": { "type": "string" }, "data_source": { "type": "string" }, "filter": { "type": "object" }, "columns": { "type": "array" }, "chart_type": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "run_advanced_report", "description": "Chạy báo cáo lưu.", "endpoint": "POST /internal/skills/run_advanced_report", "input_schema": { "type": "object", "required": ["report_id"], "properties": { "report_id": { "type": "string" }, "params": { "type": "object" } } }, "type": "action", "risk_level": "read" },
    { "name": "save_report_template", "description": "Lưu template.", "endpoint": "POST /internal/skills/save_report_template", "input_schema": { "type": "object", "required": ["name", "config"], "properties": { "name": { "type": "string" }, "config": { "type": "object" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_advanced_report", "description": "Sửa báo cáo.", "endpoint": "POST /internal/skills/update_advanced_report", "input_schema": { "type": "object", "required": ["report_id"], "properties": { "report_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_advanced_report", "description": "Xóa báo cáo.", "endpoint": "POST /internal/skills/delete_advanced_report", "input_schema": { "type": "object", "required": ["report_id"], "properties": { "report_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "schedule_report", "description": "Schedule chạy + email định kỳ.", "endpoint": "POST /internal/skills/schedule_report", "input_schema": { "type": "object", "required": ["report_id", "cron", "recipients"], "properties": { "report_id": { "type": "string" }, "cron": { "type": "string" }, "recipients": { "type": "array", "items": { "type": "string" } } } }, "type": "action", "risk_level": "normal" },
