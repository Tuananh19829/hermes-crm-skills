    { "name": "share_dashboard", "description": "Chia sẻ dashboard.", "endpoint": "POST /internal/skills/share_dashboard", "input_schema": { "type": "object", "required": ["dashboard_id", "user_ids"], "properties": { "dashboard_id": { "type": "string" }, "user_ids": { "type": "array", "items": { "type": "string" } } } }, "type": "action", "risk_level": "normal" },
    { "name": "multi_period_comparison", "description": "So sánh nhiều kỳ.", "endpoint": "POST /internal/skills/multi_period_comparison", "input_schema": { "type": "object", "required": ["metric", "periods"], "properties": { "metric": { "type": "string" }, "periods": { "type": "array" } } }, "type": "action", "risk_level": "read" },
    { "name": "drill_down_metric", "description": "Drill-down từ chart.", "endpoint": "POST /internal/skills/drill_down_metric", "input_schema": { "type": "object", "required": ["parent_metric", "dimension", "value"], "properties": { "parent_metric": { "type": "string" }, "dimension": { "type": "string" }, "value": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_kpi_targets", "description": "Mục tiêu KPI đã set.", "endpoint": "POST /internal/skills/list_kpi_targets", "input_schema": { "type": "object", "properties": { "period": { "type": "string" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_kpi_history", "description": "Lịch sử KPI.", "endpoint": "POST /internal/skills/list_kpi_history", "input_schema": { "type": "object", "properties": { "from_period": { "type": "string" }, "to_period": { "type": "string" }, "staff_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "create_kpi_target", "description": "Tạo target KPI.", "endpoint": "POST /internal/skills/create_kpi_target", "input_schema": { "type": "object", "required": ["staff_id", "month", "metric", "target_value"], "properties": { "staff_id": { "type": "string" }, "month": { "type": "string" }, "metric": { "type": "string" }, "target_value": { "type": "number" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_kpi_target", "description": "Sửa target.", "endpoint": "POST /internal/skills/update_kpi_target", "input_schema": { "type": "object", "required": ["target_id", "target_value"], "properties": { "target_id": { "type": "string" }, "target_value": { "type": "number" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_kpi_target", "description": "Xóa target.", "endpoint": "POST /internal/skills/delete_kpi_target", "input_schema": { "type": "object", "required": ["target_id"], "properties": { "target_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "bulk_set_kpi_targets", "description": "Bulk set target.", "endpoint": "POST /internal/skills/bulk_set_kpi_targets", "input_schema": { "type": "object", "required": ["period", "targets"], "properties": { "period": { "type": "string" }, "targets": { "type": "array" } } }, "type": "action", "risk_level": "high" },
    { "name": "manage_kpi_metrics", "description": "Hybrid CRUD KPI metrics/công thức.", "endpoint": "POST /internal/skills/manage_kpi_metrics", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["list", "create", "update", "delete"] }, "metric_id": { "type": "string" }, "metric_data": { "type": "object" } } }, "type": "action", "risk_level": "high" },
    { "name": "kpi_underperformers", "description": "NV không đạt KPI.", "endpoint": "POST /internal/skills/kpi_underperformers", "input_schema": { "type": "object", "properties": { "period": { "type": "string" }, "threshold": { "type": "number", "default": 80 }, "staff_filter": { "type": "object" } } }, "type": "action", "risk_level": "read" }
  ]
}
