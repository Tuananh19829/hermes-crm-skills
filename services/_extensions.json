{
  "app": "crm",
  "module": "services",
  "version": "2.1.0-ext",
  "merge_into": "_index.json",
  "skills": [
    { "name": "services_summary", "description": "Tổng quan DV + Combo.", "endpoint": "POST /internal/skills/services_summary", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "delete_service", "description": "Xóa DV.", "endpoint": "POST /internal/skills/delete_service", "input_schema": { "type": "object", "required": ["service_id"], "properties": { "service_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "toggle_service", "description": "Bật/tắt DV.", "endpoint": "POST /internal/skills/toggle_service", "input_schema": { "type": "object", "required": ["service_id", "is_active"], "properties": { "service_id": { "type": "string" }, "is_active": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "duplicate_service", "description": "Sao chép DV.", "endpoint": "POST /internal/skills/duplicate_service", "input_schema": { "type": "object", "required": ["service_id"], "properties": { "service_id": { "type": "string" }, "new_name": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "import_services", "description": "Import Excel DV.", "endpoint": "POST /internal/skills/import_services", "input_schema": { "type": "object", "required": ["file_url"], "properties": { "file_url": { "type": "string" }, "mapping": { "type": "object" } } }, "type": "action", "risk_level": "high" },
    { "name": "export_services", "description": "Export Excel DV.", "endpoint": "POST /internal/skills/export_services", "input_schema": { "type": "object", "properties": { "filter": { "type": "object" } } }, "type": "action", "risk_level": "read" },
    { "name": "manage_service_categories", "description": "Hybrid CRUD danh mục DV.", "endpoint": "POST /internal/skills/manage_service_categories", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["list", "create", "update", "delete"] }, "category_id": { "type": "string" }, "category_data": { "type": "object" } } }, "type": "action", "risk_level": "normal" },
    { "name": "get_bundle_detail", "description": "Chi tiết combo.", "endpoint": "POST /internal/skills/get_bundle_detail", "input_schema": { "type": "object", "required": ["bundle_id"], "properties": { "bundle_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "update_bundle", "description": "Sửa combo.", "endpoint": "POST /internal/skills/update_bundle", "input_schema": { "type": "object", "required": ["bundle_id"], "properties": { "bundle_id": { "type": "string" }, "name": { "type": "string" }, "items": { "type": "array" }, "bundle_price": { "type": "number" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_bundle", "description": "Xóa combo.", "endpoint": "POST /internal/skills/delete_bundle", "input_schema": { "type": "object", "required": ["bundle_id"], "properties": { "bundle_id": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "toggle_bundle", "description": "Bật/tắt combo.", "endpoint": "POST /internal/skills/toggle_bundle", "input_schema": { "type": "object", "required": ["bundle_id", "is_active"], "properties": { "bundle_id": { "type": "string" }, "is_active": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "treatments_summary", "description": "Tổng quan liệu trình KH.", "endpoint": "POST /internal/skills/treatments_summary", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "treatments_report", "description": "Báo cáo liệu trình.", "endpoint": "POST /internal/skills/treatments_report", "input_schema": { "type": "object", "properties": { "period": { "type": "string", "enum": ["month", "quarter", "year"] } } }, "type": "action", "risk_level": "read" },
    { "name": "update_treatment_status", "description": "Đổi status liệu trình.", "endpoint": "POST /internal/skills/update_treatment_status", "input_schema": { "type": "object", "required": ["treatment_id", "status"], "properties": { "treatment_id": { "type": "string" }, "status": { "type": "string", "enum": ["ACTIVE", "PAUSED", "COMPLETED", "EXPIRED", "CANCELLED"] } } }, "type": "action", "risk_level": "normal" },
    { "name": "consume_treatment_session", "description": "Trừ 1 buổi liệu trình.", "endpoint": "POST /internal/skills/consume_treatment_session", "input_schema": { "type": "object", "required": ["treatment_id"], "properties": { "treatment_id": { "type": "string" }, "staff_id": { "type": "string" }, "service_date": { "type": "string", "format": "date-time" }, "note": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "revert_treatment_session", "description": "Hoàn lại buổi đã trừ.", "endpoint": "POST /internal/skills/revert_treatment_session", "input_schema": { "type": "object", "required": ["session_id", "reason"], "properties": { "session_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "extend_treatment", "description": "Gia hạn liệu trình.", "endpoint": "POST /internal/skills/extend_treatment", "input_schema": { "type": "object", "required": ["treatment_id", "new_expires_at"], "properties": { "treatment_id": { "type": "string" }, "new_expires_at": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "normal" },
    { "name": "update_treatment", "description": "Sửa liệu trình.", "endpoint": "POST /internal/skills/update_treatment", "input_schema": { "type": "object", "required": ["treatment_id"], "properties": { "treatment_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_treatment", "description": "Xóa liệu trình.", "endpoint": "POST /internal/skills/delete_treatment", "input_schema": { "type": "object", "required": ["treatment_id"], "properties": { "treatment_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "notify_low_session_treatments", "description": "Nhắc KH sắp hết buổi.", "endpoint": "POST /internal/skills/notify_low_session_treatments", "input_schema": { "type": "object", "properties": { "days_ahead": { "type": "integer", "default": 7 }, "auto_send_zalo": { "type": "boolean", "default": false } } }, "type": "action", "risk_level": "normal" },
    { "name": "transfer_treatment", "description": "Chuyển nhượng liệu trình.", "endpoint": "POST /internal/skills/transfer_treatment", "input_schema": { "type": "object", "required": ["treatment_id", "new_person_id"], "properties": { "treatment_id": { "type": "string" }, "new_person_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "reschedule_appointment", "description": "Đổi giờ lịch hẹn + thông báo KH.", "endpoint": "POST /internal/skills/reschedule_appointment", "input_schema": { "type": "object", "required": ["appointment_id", "new_start_at"], "properties": { "appointment_id": { "type": "string" }, "new_start_at": { "type": "string", "format": "date-time" }, "notify_customer": { "type": "boolean", "default": true }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "check_room_availability", "description": "Check phòng/giường trống slot.", "endpoint": "POST /internal/skills/check_room_availability", "input_schema": { "type": "object", "required": ["start_at", "duration_min"], "properties": { "start_at": { "type": "string", "format": "date-time" }, "duration_min": { "type": "integer" }, "branch_id": { "type": "string" } } }, "type": "action", "risk_level": "read" }
  ]
}
