{
  "app": "crm",
  "module": "ads",
  "version": "2.1.0-ext",
  "merge_into": "_index.json",
  "skills": [
    { "name": "ads_dashboard_summary", "description": "Tổng quan dashboard Ads (kênh+campaign).", "endpoint": "POST /internal/skills/ads_dashboard_summary", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "create_ad_campaign", "description": "Tạo campaign mới.", "endpoint": "POST /internal/skills/create_ad_campaign", "input_schema": { "type": "object", "required": ["name", "platform", "budget"], "properties": { "name": { "type": "string" }, "platform": { "type": "string", "enum": ["facebook", "google", "tiktok", "zalo"] }, "budget": { "type": "number" }, "target": { "type": "object" }, "from_date": { "type": "string", "format": "date" }, "to_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "high" },
    { "name": "get_ad_campaign_detail", "description": "Chi tiết campaign.", "endpoint": "POST /internal/skills/get_ad_campaign_detail", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "list_ad_campaigns", "description": "List campaigns.", "endpoint": "POST /internal/skills/list_ad_campaigns", "input_schema": { "type": "object", "properties": { "platform": { "type": "string" }, "status": { "type": "string" }, "period": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "update_ad_campaign", "description": "Sửa campaign.", "endpoint": "POST /internal/skills/update_ad_campaign", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "toggle_ad_campaign", "description": "Bật/tắt campaign.", "endpoint": "POST /internal/skills/toggle_ad_campaign", "input_schema": { "type": "object", "required": ["campaign_id", "enabled"], "properties": { "campaign_id": { "type": "string" }, "enabled": { "type": "boolean" } } }, "type": "action", "risk_level": "normal" },
    { "name": "delete_ad_campaign", "description": "Xóa campaign.", "endpoint": "POST /internal/skills/delete_ad_campaign", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" }, "reason": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "ad_campaign_report", "description": "Báo cáo ROI campaign.", "endpoint": "POST /internal/skills/ad_campaign_report", "input_schema": { "type": "object", "required": ["campaign_id"], "properties": { "campaign_id": { "type": "string" }, "period": { "type": "string" }, "include_revenue_attribution": { "type": "boolean", "default": true } } }, "type": "action", "risk_level": "read" },
    { "name": "top_ad_campaigns", "description": "Top campaign.", "endpoint": "POST /internal/skills/top_ad_campaigns", "input_schema": { "type": "object", "properties": { "period": { "type": "string" }, "sort_by": { "type": "string", "enum": ["leads", "cpl", "roas"] }, "top_n": { "type": "integer", "default": 10 } } }, "type": "action", "risk_level": "read" },
    { "name": "sync_ad_campaigns_from_platform", "description": "Sync data từ platform.", "endpoint": "POST /internal/skills/sync_ad_campaigns_from_platform", "input_schema": { "type": "object", "required": ["platform"], "properties": { "platform": { "type": "string" }, "from_date": { "type": "string", "format": "date" } } }, "type": "action", "risk_level": "high" },
    { "name": "ads_leads_summary", "description": "Tổng quan leads.", "endpoint": "POST /internal/skills/ads_leads_summary", "input_schema": { "type": "object", "properties": { "period": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "auto_assign_lead", "description": "Auto-assign lead.", "endpoint": "POST /internal/skills/auto_assign_lead", "input_schema": { "type": "object", "required": ["lead_id"], "properties": { "lead_id": { "type": "string" }, "rule_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "dedup_ads_leads", "description": "Dedupe leads trùng.", "endpoint": "POST /internal/skills/dedup_ads_leads", "input_schema": { "type": "object", "required": ["source", "timeframe"], "properties": { "source": { "type": "string" }, "timeframe": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "enrich_lead", "description": "Enrich lead với external API.", "endpoint": "POST /internal/skills/enrich_lead", "input_schema": { "type": "object", "required": ["lead_id"], "properties": { "lead_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "ads_conversion_funnel_report", "description": "Conversion funnel ads.", "endpoint": "POST /internal/skills/ads_conversion_funnel_report", "input_schema": { "type": "object", "properties": { "period": { "type": "string" }, "source": { "type": "string" }, "campaign_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "webhook_logs_summary", "description": "Tổng webhook logs theo status.", "endpoint": "POST /internal/skills/webhook_logs_summary", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "list_webhook_logs", "description": "List webhook logs.", "endpoint": "POST /internal/skills/list_webhook_logs", "input_schema": { "type": "object", "properties": { "from_date": { "type": "string", "format": "date" }, "to_date": { "type": "string", "format": "date" }, "status": { "type": "string" }, "source": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "get_webhook_log_detail", "description": "Chi tiết webhook log.", "endpoint": "POST /internal/skills/get_webhook_log_detail", "input_schema": { "type": "object", "required": ["log_id"], "properties": { "log_id": { "type": "string" } } }, "type": "action", "risk_level": "read" },
    { "name": "replay_webhook", "description": "Replay webhook.", "endpoint": "POST /internal/skills/replay_webhook", "input_schema": { "type": "object", "required": ["log_id"], "properties": { "log_id": { "type": "string" } } }, "type": "action", "risk_level": "normal" },
    { "name": "export_webhook_logs", "description": "Export logs.", "endpoint": "POST /internal/skills/export_webhook_logs", "input_schema": { "type": "object", "properties": { "filter": { "type": "object" } } }, "type": "action", "risk_level": "read" },
    { "name": "connect_ads_platform", "description": "Kết nối platform Ads.", "endpoint": "POST /internal/skills/connect_ads_platform", "input_schema": { "type": "object", "required": ["platform"], "properties": { "platform": { "type": "string" }, "oauth_code": { "type": "string" }, "api_key": { "type": "string" } } }, "type": "action", "risk_level": "high" },
    { "name": "get_webhook_config", "description": "URL+secret webhook endpoint.", "endpoint": "POST /internal/skills/get_webhook_config", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "regenerate_webhook_secret", "description": "Regenerate signing secret.", "endpoint": "POST /internal/skills/regenerate_webhook_secret", "input_schema": { "type": "object", "required": ["confirm"], "properties": { "confirm": { "type": "boolean" } } }, "type": "action", "risk_level": "high" },
    { "name": "update_lead_assignment_rules", "description": "Cập nhật rules auto-assign.", "endpoint": "POST /internal/skills/update_lead_assignment_rules", "input_schema": { "type": "object", "required": ["rules"], "properties": { "rules": { "type": "object", "properties": { "round_robin": { "type": "boolean" }, "prefer_online": { "type": "boolean" }, "skip_after_hours": { "type": "boolean" } } } } }, "type": "action", "risk_level": "normal" },
    { "name": "get_lead_assignment_rules", "description": "Get rules hiện tại.", "endpoint": "POST /internal/skills/get_lead_assignment_rules", "input_schema": { "type": "object", "properties": {} }, "type": "action", "risk_level": "read" },
    { "name": "manage_crm_to_ads_sync", "description": "Hybrid CRM→Ads sync config.", "endpoint": "POST /internal/skills/manage_crm_to_ads_sync", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["get", "update", "run_now"] }, "sync_config": { "type": "object" } } }, "type": "action", "risk_level": "high" },
    { "name": "manage_lead_field_mapping", "description": "Hybrid mapping field FB lead form → CRM.", "endpoint": "POST /internal/skills/manage_lead_field_mapping", "input_schema": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "enum": ["get", "update"] }, "platform": { "type": "string" }, "mapping": { "type": "object" } } }, "type": "action", "risk_level": "normal" }
  ]
}
