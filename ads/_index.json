{
  "app": "crm",
  "version": "2.0.0",
  "base_url": "https://crm.spaclaw.pro",
  "auth": {
    "header_secret": "X-Internal-Secret",
    "header_user": "X-User-Id",
    "header_group": "X-Group-Id",
    "note": "workspace_id resolved server-side from X-User-Id + X-Group-Id"
  },
  "skills": [
    {
      "name": "ads_dashboard",
      "description": "Tổng quan hiệu quả quảng cáo: số leads, CPL, tỉ lệ chuyển đổi, chi phí theo kênh. Dùng khi user hỏi 'ads hôm nay thế nào', 'CPL tháng này', 'hiệu quả quảng cáo'.",
      "triggers": ["ads dashboard", "tổng quan quảng cáo", "cpl", "chi phí quảng cáo", "hiệu quả ads", "leads hôm nay", "chuyển đổi ads"],
      "endpoint": "POST /internal/skills/ads_dashboard",
      "input_schema": {
        "type": "object",
        "properties": {
          "period": { "type": "string", "enum": ["today", "week", "month"], "default": "today" },
          "from_date": { "type": "string", "format": "date" },
          "to_date": { "type": "string", "format": "date" },
          "channel": { "type": "string", "description": "Lọc theo kênh: facebook, google, zalo, tiktok hoặc để trống = tất cả" }
        }
      }
    },
    {
      "name": "list_ads_leads",
      "description": "Danh sách leads đến từ quảng cáo, lọc theo nguồn/trạng thái/nhân viên phụ trách. Dùng khi user hỏi 'leads facebook hôm nay', 'leads chưa gọi', 'leads của NV X'.",
      "triggers": ["leads ads", "leads facebook", "leads quảng cáo", "danh sách leads", "list ads leads", "leads chưa gọi", "leads mới"],
      "endpoint": "POST /internal/skills/list_ads_leads",
      "input_schema": {
        "type": "object",
        "properties": {
          "source": { "type": "string", "description": "facebook | google | zalo | tiktok | referral" },
          "status": { "type": "string", "enum": ["NEW", "CONTACTED", "QUALIFIED", "WON", "LOST"] },
          "assigned_to": { "type": "string", "description": "UUID nhân viên phụ trách" },
          "from_date": { "type": "string", "format": "date" },
          "to_date": { "type": "string", "format": "date" },
          "limit": { "type": "integer", "default": 20, "maximum": 100 }
        }
      }
    },
    {
      "name": "update_lead_funnel",
      "description": "Di chuyển lead qua các bước funnel CRM (Mới→Quan tâm→Đặt lịch→Chốt). Dùng khi user nói 'kh X đã quan tâm', 'chuyển lead sang đặt lịch', 'move funnel'.",
      "triggers": ["di chuyển lead", "chuyển funnel", "move lead", "update funnel", "lead quan tâm", "lead đặt lịch", "chuyển bước"],
      "endpoint": "POST /internal/skills/update_lead_funnel",
      "input_schema": {
        "type": "object",
        "required": ["lead_id", "stage"],
        "properties": {
          "lead_id": { "type": "string", "description": "UUID lead hoặc person_id" },
          "stage": { "type": "string", "enum": ["NEW", "INTERESTED", "APPOINTMENT", "WON", "LOST"], "description": "Bước funnel mới" },
          "note": { "type": "string", "description": "Ghi chú lý do chuyển bước" },
          "follow_up_at": { "type": "string", "format": "date-time", "description": "Lịch follow-up tiếp theo nếu có" }
        }
      }
    },
    {
      "name": "telesale_call_log",
      "description": "Ghi log cuộc gọi telesale: kết quả, ghi chú, thời gian gọi lại. Dùng khi NV báo 'đã gọi kh X', 'kh không bắt máy', 'hẹn gọi lại lúc 3h'.",
      "triggers": ["ghi cuộc gọi", "log call", "call log", "đã gọi", "không bắt máy", "hẹn gọi lại", "telesale log"],
      "endpoint": "POST /internal/skills/telesale_call_log",
      "input_schema": {
        "type": "object",
        "required": ["person_id", "result"],
        "properties": {
          "person_id": { "type": "string" },
          "result": { "type": "string", "enum": ["ANSWERED", "NO_ANSWER", "BUSY", "CALLBACK", "WON", "NOT_INTERESTED"], "description": "Kết quả cuộc gọi" },
          "duration_seconds": { "type": "integer", "description": "Thời lượng cuộc gọi (giây)" },
          "note": { "type": "string", "description": "Ghi chú nội dung cuộc gọi" },
          "callback_at": { "type": "string", "format": "date-time", "description": "Thời gian gọi lại (nếu result=CALLBACK)" }
        }
      }
    },
    {
      "name": "list_telesale_queue",
      "description": "Danh sách số cần gọi hôm nay theo nhân viên, ưu tiên theo hẹn callback. Dùng khi NV hỏi 'hôm nay tôi gọi ai', 'danh sách telesale', 'queue gọi điện'.",
      "triggers": ["danh sách gọi", "queue telesale", "hôm nay gọi ai", "telesale queue", "lịch gọi", "ai cần gọi"],
      "endpoint": "POST /internal/skills/list_telesale_queue",
      "input_schema": {
        "type": "object",
        "properties": {
          "assigned_to": { "type": "string", "description": "UUID nhân viên, mặc định = người đang gọi API" },
          "date": { "type": "string", "format": "date", "description": "Ngày cần xem, mặc định = hôm nay" },
          "include_callbacks": { "type": "boolean", "default": true, "description": "Bao gồm các cuộc hẹn gọi lại" },
          "limit": { "type": "integer", "default": 30, "maximum": 100 }
        }
      }
    },
    {
      "name": "send_zalo_message",
      "description": "Gửi tin nhắn Zalo cho 1 khách hàng cụ thể. Dùng khi user muốn nhắn Zalo cá nhân: 'nhắn Zalo kh X', 'gửi tin Zalo cho số 0901...'.",
      "triggers": ["gửi zalo", "nhắn zalo", "send zalo", "zalo kh", "nhắn tin zalo", "zalo message"],
      "endpoint": "POST /internal/skills/send_zalo_message",
      "input_schema": {
        "type": "object",
        "required": ["person_id", "message"],
        "properties": {
          "person_id": { "type": "string", "description": "UUID khách hàng (đã liên kết Zalo)" },
          "message": { "type": "string", "description": "Nội dung tin nhắn" },
          "template_id": { "type": "string", "description": "ID template nếu dùng ZNS template" },
          "template_data": { "type": "object", "description": "Dữ liệu điền vào template (nếu dùng template)" }
        }
      }
    },
    {
      "name": "send_zalo_broadcast",
      "description": "Gửi broadcast Zalo cho nhóm khách hàng theo điều kiện lọc. Dùng khi user muốn gửi hàng loạt: 'gửi Zalo cho kh VIP', 'broadcast Zalo chưa mua tháng này'.",
      "triggers": ["broadcast zalo", "gửi zalo hàng loạt", "zalo broadcast", "nhắn nhiều kh", "gửi bulk zalo", "gửi zalo nhóm"],
      "endpoint": "POST /internal/skills/send_zalo_broadcast",
      "input_schema": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": { "type": "string", "description": "Nội dung tin nhắn broadcast" },
          "template_id": { "type": "string" },
          "template_data": { "type": "object" },
          "filter": {
            "type": "object",
            "description": "Điều kiện lọc người nhận",
            "properties": {
              "tags": { "type": "array", "items": { "type": "string" } },
              "lead_status": { "type": "string", "enum": ["NEW", "CONTACTED", "QUALIFIED", "WON", "LOST"] },
              "last_order_before": { "type": "string", "format": "date" },
              "last_order_after": { "type": "string", "format": "date" }
            }
          },
          "dry_run": { "type": "boolean", "default": false, "description": "true = chỉ đếm người nhận, không gửi thật" }
        }
      }
    },
    {
      "name": "list_zalo_templates",
      "description": "Xem danh sách template Zalo (ZNS) đã cấu hình trong workspace. Dùng khi user hỏi 'có template Zalo nào', 'list zalo template', 'template nhắn kh'.",
      "triggers": ["template zalo", "zalo template", "list template", "zns template", "mẫu tin zalo"],
      "endpoint": "POST /internal/skills/list_zalo_templates",
      "input_schema": {
        "type": "object",
        "properties": {
          "active_only": { "type": "boolean", "default": true, "description": "Chỉ lấy template đang hoạt động" },
          "limit": { "type": "integer", "default": 20 }
        }
      }
    },
    {
      "name": "ai_analyze_customer",
      "description": "AI phân tích hành vi, sở thích, vòng đời khách hàng và gợi ý dịch vụ phù hợp. Dùng khi user hỏi 'kh X phù hợp dịch vụ gì', 'phân tích kh', 'AI nhận xét khách'.",
      "triggers": ["phân tích khách", "ai analyze", "gợi ý dịch vụ", "kh phù hợp gì", "nhận xét khách", "ai phân tích"],
      "endpoint": "POST /internal/skills/ai_analyze_customer",
      "input_schema": {
        "type": "object",
        "required": ["person_id"],
        "properties": {
          "person_id": { "type": "string" },
          "focus": { "type": "string", "enum": ["behavior", "preferences", "lifetime_value", "churn_risk", "upsell"], "description": "Góc phân tích cụ thể, mặc định = toàn diện" }
        }
      }
    },
    {
      "name": "ai_suggest_followup",
      "description": "AI gợi ý nội dung follow-up phù hợp cho khách hàng cụ thể (tin nhắn, ưu đãi, timing). Dùng khi NV hỏi 'nên nhắn gì cho kh X', 'follow-up kh X thế nào'.",
      "triggers": ["gợi ý follow-up", "nhắn gì cho kh", "follow up kh", "ai suggest", "nên liên hệ thế nào", "ai gợi ý"],
      "endpoint": "POST /internal/skills/ai_suggest_followup",
      "input_schema": {
        "type": "object",
        "required": ["person_id"],
        "properties": {
          "person_id": { "type": "string" },
          "channel": { "type": "string", "enum": ["zalo", "call", "email", "any"], "default": "any", "description": "Kênh liên hệ ưu tiên" },
          "context": { "type": "string", "description": "Ngữ cảnh bổ sung (ví dụ: 'kh vừa hỏi về dịch vụ X')" }
        }
      }
    },
    {
